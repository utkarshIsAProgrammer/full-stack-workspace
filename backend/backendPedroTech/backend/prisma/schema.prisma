// auto generated code
generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// schema
model User{
  id String @id @default(uuid())
  name String
  email String @unique
  password String
  createdAt DateTime @default(now())
}

model Movies{
  id String @id @default(uuid())
  name String
  overview String?
  releaseYear Int
  genres String[] @default([])
  runtime Int?
  posterURL String?
  createdBy String
  createdAt DateTime @default(now())

}

model WatchListItem{
  id String @id @default(uuid())
  userId String
  movieId String
  status WatchListStatus @default(PLANNED)
  rating Int?
  notes String?
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())

// relations
user User @relation(fields:[userId], references: [id])
}

// enum list for WatchListItem
enum WatchListStatus{
  PLANNED
  WATCHING
  COMPLETED
  DROPPED
}